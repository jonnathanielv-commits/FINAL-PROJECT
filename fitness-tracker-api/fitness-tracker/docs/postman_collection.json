{
  "info": {
    "name": "Fitness Tracker API",
    "_postman_id": "fitness-tracker-api-collection",
    "description": "Complete endpoint collection for the CPE 114 Fitness Tracker REST API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users",
            "description": "Returns a list of all registered users."
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/1",
            "description": "Returns a single user by their ID, including their associated workouts. Returns 404 if not found."
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan dela Cruz\",\n  \"email\": \"juan@example.com\",\n  \"age\": 22,\n  \"weight_kg\": 70,\n  \"height_cm\": 175\n}"
            },
            "description": "Creates a new user. Requires 'name' and 'email'. Returns 201 on success, 400 if fields are missing or email is taken."
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan dela Cruz\",\n  \"weight_kg\": 68\n}"
            },
            "description": "Updates an existing user by ID. Returns 404 if not found."
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/users/1",
            "description": "Deletes a user by ID. Also cascades to delete their workouts. Returns 404 if not found."
          }
        }
      ]
    },
    {
      "name": "Exercises",
      "item": [
        {
          "name": "Get All Exercises",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/exercises",
            "description": "Returns a list of all available exercises in the database."
          }
        },
        {
          "name": "Get Exercise By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/exercises/1",
            "description": "Returns a single exercise by ID. Returns 404 if not found."
          }
        },
        {
          "name": "Create Exercise",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/exercises",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Barbell Squat\",\n  \"muscle_group\": \"Legs\",\n  \"description\": \"A compound lower-body movement.\",\n  \"equipment\": \"Barbell\"\n}"
            },
            "description": "Creates a new exercise. Requires 'name' and 'muscle_group'. Returns 201 on success."
          }
        },
        {
          "name": "Update Exercise",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/exercises/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description for Barbell Squat.\"\n}"
            },
            "description": "Updates an exercise by ID. Returns 404 if not found."
          }
        },
        {
          "name": "Delete Exercise",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/exercises/1",
            "description": "Deletes an exercise by ID. Returns 404 if not found."
          }
        }
      ]
    },
    {
      "name": "Workouts",
      "item": [
        {
          "name": "Get All Workouts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/workouts",
            "description": "Returns all workouts with the associated user (name and id)."
          }
        },
        {
          "name": "Get Workout By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/workouts/1",
            "description": "Returns a single workout with full user info and all included exercises (with sets/reps). Returns 404 if not found."
          }
        },
        {
          "name": "Create Workout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/workouts",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Morning Strength Session\",\n  \"date\": \"2025-06-01\",\n  \"duration_minutes\": 60,\n  \"notes\": \"Focused on compound lifts.\",\n  \"userId\": 1\n}"
            },
            "description": "Creates a new workout. Requires 'title', 'date', 'duration_minutes', and 'userId'. Returns 201 on success."
          }
        },
        {
          "name": "Update Workout",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/workouts/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"duration_minutes\": 75,\n  \"notes\": \"Added extra sets.\"\n}"
            },
            "description": "Updates a workout by ID. Returns 404 if not found."
          }
        },
        {
          "name": "Delete Workout",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/workouts/1",
            "description": "Deletes a workout by ID. Returns 404 if not found."
          }
        },
        {
          "name": "List Exercises in Workout",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/workouts/1/exercises",
            "description": "Returns all exercises assigned to a specific workout, with junction data (sets, reps, weight). Returns 404 if workout not found."
          }
        },
        {
          "name": "Add Exercise to Workout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/workouts/1/exercises",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"exerciseId\": 1,\n  \"sets\": 4,\n  \"reps\": 8,\n  \"weight_kg\": 80,\n  \"duration_seconds\": null\n}"
            },
            "description": "Assigns an exercise to a workout through the junction table, with optional sets/reps/weight. Returns 201 on success."
          }
        },
        {
          "name": "Remove Exercise from Workout",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/workouts/1/exercises/1",
            "description": "Removes an exercise from a workout (deletes the junction record only). Returns 404 if workout or exercise not found."
          }
        }
      ]
    }
  ]
}
